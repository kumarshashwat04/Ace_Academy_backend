# Server
PORT=3001
NODE_ENV=development

# CORS (comma-separated origins, or * for all)
CORS_ORIGIN=*

# PostgreSQL — ace_academy database on the VM.
# Use 127.0.0.1 if the API runs ON the VM; use 172.35.0.13 if it connects remotely.
DB_HOST=172.35.0.13
DB_PORT=5432
DB_NAME=ace_academy
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# Optional: enable SSL for the DB connection (true/false)
DB_SSL=false

# Connection pool tuning (optional)
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=10000
